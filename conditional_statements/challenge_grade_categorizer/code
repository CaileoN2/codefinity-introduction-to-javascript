function getStudentGrade() {
  let grade = 85;
  let message = "";

  if (grade >= 90) {
    message = "Grade: A";
  } else if (grade >= 80) {
    message = "Grade: B";
  } else if (grade >= 70) {
    message = "Grade: C";
  } else if (grade >= 60) {
    message = "Grade: D";
  } else {
    message = "Grade: F";
  }

  return message;
}

console.log(getStudentGrade());
